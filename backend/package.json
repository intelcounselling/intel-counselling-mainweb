{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npx --no-install prisma generate",
    "postinstall": "npx --no-install prisma generate",
    "db:generate": "npx --no-install prisma generate",
    "db:push": "npx --no-install prisma db push",
    "db:migrate": "npx --no-install prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx --no-install prisma studio",
    "db:reset": "npx --no-install prisma migrate reset --force && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "firebase-admin": "^14.2.0",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.11",
    "pdfkit": "^0.18.0",
    "pdfkit-table": "^0.2.11",
    "prisma": "^5.10.0",
    "sqlite3": "^5.1.7",
    "twilio": "^5.0.4",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
